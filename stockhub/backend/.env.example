# StockHub 环境配置

# 服务端口
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=stockhub123
DB_DATABASE=stockhub
DB_SYNCHRONIZE=true

# JWT配置
JWT_SECRET=stockhub-jwt-secret-key-2026
JWT_EXPIRE=7d

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 跨域配置
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# 文件上传
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE=52428800

# 邮件配置（可选）
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@stockhub.com
MAIL_PASSWORD=

# 货代API配置（可选）
YUNTU_API_KEY=
YUNTU_SECRET=
